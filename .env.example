# ════════════════════════════════════════
#  ShopCid — Configuration
#  Copier ce fichier en .env et remplir
# ════════════════════════════════════════

# OBLIGATOIRE — Clé secrète JWT (changez cette valeur !)
# Générer: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=changez_moi_avec_une_longue_chaine_aleatoire

# URL du site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── PRODUCTION SEULEMENT (laisser vide en développement) ──────────────────────
# URL PostgreSQL (format: postgresql://user:password@host:5432/dbname)
DATABASE_URL=

# Activer SSL pour PostgreSQL (true sur la plupart des hébergeurs cloud)
DATABASE_SSL=false

# ── OPTIONNEL ─────────────────────────────────────────────────────────────────
# Clé API Anthropic pour l'assistant IA
# Obtenez-la sur https://console.anthropic.com
ANTHROPIC_API_KEY=
